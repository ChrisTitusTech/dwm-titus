root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h}]
indent_style = tab
indent_size = 8

[{Makefile,*.mk}]
indent_style = tab

[*.{sh,bash}]
indent_style = tab
indent_size = 4

[*.{md,yaml,yml,toml,qml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
