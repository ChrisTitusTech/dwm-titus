#!/usr/bin/env bash
set -euo pipefail

usage() {
	cat <<'EOF'
Usage: scripts/dwm-titus-release [options]

Create a GitHub release for the current config.mk VERSION, then bump config.mk
to the next minor version.

Options:
  --version VERSION       Confirm the committed config.mk VERSION to release.
                          Accepts 0.5.0 or v0.5.0.
  --iso PATH              Upload an installer ISO alongside the source archive.
  --notes FILE            Use FILE as release notes.
  --dry-run               Print the planned commands and version bump only.
  --skip-checks           Skip make release-check.
  --no-bump               Do not bump config.mk after release creation.
  -h, --help              Show this help.
EOF
}

err() {
	printf 'dwm-titus-release: %s\n' "$*" >&2
}

run() {
	if [[ $dry_run == true ]]; then
		printf '+'
		printf ' %q' "$@"
		printf '\n'
	else
		"$@"
	fi
}

remote_tag_exists() {
	gh api "repos/:owner/:repo/git/ref/tags/$tag" >/dev/null 2>&1
}

remote_release_exists() {
	gh release view "$tag" >/dev/null 2>&1
}

expand_user_path() {
	case "$1" in
	\~)
		printf '%s\n' "$HOME"
		;;
	\~/*)
		printf '%s/%s\n' "$HOME" "${1#"~/"}"
		;;
	*)
		printf '%s\n' "$1"
		;;
	esac
}

prompt_for_iso() {
	local fallback answer

	fallback="$HOME/Downloads/dwm-titus.iso"
	if [[ ! -t 0 ]]; then
		err "ISO not found at $default_iso_path; continuing without ISO upload. Use --iso PATH to upload one."
		return 0
	fi

	if [[ -f $fallback ]]; then
		printf 'ISO not found at %s.\n' "$default_iso_path" >&2
		printf 'Path to dwm-titus.iso [%s]: ' "$fallback" >&2
	else
		printf 'ISO not found at %s.\n' "$default_iso_path" >&2
		printf 'Path to dwm-titus.iso (leave blank to skip ISO upload): ' >&2
	fi
	IFS= read -r answer

	if [[ -z $answer && -f $fallback ]]; then
		iso_path=$fallback
	elif [[ -n $answer ]]; then
		iso_path="$(expand_user_path "$answer")"
	fi
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
config_mk="$repo_root/config.mk"
default_iso_path="$repo_root/dwm-titus.iso"
release_version=
iso_path=
notes_file=
dry_run=false
skip_checks=false
bump_after_release=true

while (($# > 0)); do
	case "$1" in
	--version)
		if (($# < 2)); then
			err "--version requires a value."
			exit 1
		fi
		release_version=$2
		shift 2
		;;
	--version=*)
		release_version=${1#*=}
		shift
		;;
	--iso)
		if (($# < 2)); then
			err "--iso requires a value."
			exit 1
		fi
		iso_path=$2
		shift 2
		;;
	--iso=*)
		iso_path=${1#*=}
		shift
		;;
	--notes)
		if (($# < 2)); then
			err "--notes requires a value."
			exit 1
		fi
		notes_file=$2
		shift 2
		;;
	--notes=*)
		notes_file=${1#*=}
		shift
		;;
	--dry-run)
		dry_run=true
		shift
		;;
	--skip-checks)
		skip_checks=true
		shift
		;;
	--no-bump)
		bump_after_release=false
		shift
		;;
	-h | --help)
		usage
		exit 0
		;;
	*)
		err "unknown argument: $1"
		usage >&2
		exit 1
		;;
	esac
done

if [[ ! -f $config_mk ]]; then
	err "missing config.mk at $config_mk"
	exit 1
fi

current_version="$(
	awk -F= '
		$1 ~ /^[[:space:]]*VERSION[[:space:]]*$/ {
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2)
			print $2
			exit
		}
	' "$config_mk"
)"

if [[ -z $current_version ]]; then
	err "could not read VERSION from config.mk"
	exit 1
fi

release_version=${release_version:-$current_version}
release_version=${release_version#v}

if [[ ! $release_version =~ ^[0-9]+(\.[0-9]+){1,2}$ ]]; then
	err "version must look like MAJOR.MINOR or MAJOR.MINOR.PATCH: $release_version"
	exit 1
fi

IFS=. read -r major minor patch <<<"$release_version"
patch=${patch:-0}
release_version="$major.$minor.$patch"
tag="v$release_version"
next_version="$major.$((minor + 1)).0"
release_archive="$repo_root/release/dwm-titus-$release_version.tar.gz"
checksums="$repo_root/release/dwm-titus-$release_version-SHA256SUMS"

if [[ $release_version != "$current_version" ]]; then
	err "requested version $release_version does not match committed config.mk VERSION $current_version"
	err "update config.mk and CHANGELOG.md, commit them, then rerun the release"
	exit 1
fi

if [[ -z $iso_path ]]; then
	if [[ -f $default_iso_path ]]; then
		iso_path=$default_iso_path
	else
		prompt_for_iso
	fi
else
	iso_path="$(expand_user_path "$iso_path")"
fi

if [[ -n $iso_path && ! -f $iso_path ]]; then
	err "ISO not found: $iso_path"
	exit 1
fi

if [[ -n $notes_file && ! -f $notes_file ]]; then
	err "release notes file not found: $notes_file"
	exit 1
fi

if ! command -v gh >/dev/null 2>&1; then
	err "missing required command: gh"
	exit 1
fi

cd "$repo_root"

release_exists=false
head_sha="$(git rev-parse HEAD)"

if [[ $dry_run != true ]]; then
	if [[ -n $(git status --porcelain --untracked-files=normal) ]]; then
		err "release worktree is not clean"
		err "commit or remove local changes before creating $tag"
		exit 1
	fi
	if ! gh api "repos/:owner/:repo/commits/$head_sha" >/dev/null 2>&1; then
		err "release commit $head_sha is not available on GitHub"
		err "push the release commit before creating $tag"
		exit 1
	fi
fi

if [[ $skip_checks != true ]]; then
	run make release-check
else
	run make release
fi

assets=("$release_archive")
if [[ -n $iso_path ]]; then
	assets+=("$iso_path")
fi

if [[ $dry_run == true ]]; then
	printf '+ sha256sum'
	printf ' %q' "${assets[@]}"
	printf ' > %q\n' "$checksums"
else
	mkdir -p "$(dirname "$checksums")"
	sha256sum "${assets[@]}" >"$checksums"
fi
assets+=("$checksums")

if [[ $dry_run == true ]]; then
	run gh api "repos/:owner/:repo/git/ref/tags/$tag"
	run gh api -X POST repos/:owner/:repo/git/refs \
		-f "ref=refs/tags/$tag" \
		-f "sha=$head_sha"
	run gh release view "$tag"
else
	if remote_tag_exists; then
		printf 'Remote tag %s already exists.\n' "$tag"
	else
		printf 'Remote tag %s does not exist; creating it at %s.\n' "$tag" "$head_sha"
		run gh api -X POST repos/:owner/:repo/git/refs \
			-f "ref=refs/tags/$tag" \
			-f "sha=$head_sha" >/dev/null
	fi

	if remote_release_exists; then
		release_exists=true
	fi
fi

if [[ $release_exists == true ]]; then
	run gh release upload "$tag" "${assets[@]}" --clobber
else
	gh_args=(release create "$tag" "${assets[@]}" --title "dwm-titus $tag" --verify-tag)
	if [[ -n $notes_file ]]; then
		gh_args+=(--notes-file "$notes_file")
	else
		gh_args+=(--notes "dwm-titus $tag release.")
	fi
	run gh "${gh_args[@]}"
fi

if [[ $bump_after_release == true ]]; then
	run sed -i -E "s/^[[:space:]]*VERSION[[:space:]]*=.*/VERSION = $next_version/" "$config_mk"
	printf 'Next development version: %s\n' "$next_version"
fi
