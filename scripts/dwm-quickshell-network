#!/bin/sh
set -eu

usage() {
	printf '%s\n' "usage: dwm-quickshell-network status|devices|connections|wifi-scan [--rescan yes|no] [ifname]|wifi-connect <ifname> <bssid> <ssid> [password]|connect <uuid>|disconnect <device>|monitor|editor" >&2
	exit 2
}

need_nmcli() {
	if ! command -v nmcli >/dev/null 2>&1; then
		printf '%s\n' "nmcli not found" >&2
		exit 127
	fi
}

nmcli_tab() {
	nmcli --terse --escape yes "$@" |
		awk '
			{
				field = ""
				output = ""
				count = 0
				escaped = 0
				for (i = 1; i <= length($0); i++) {
					char = substr($0, i, 1)
					if (escaped) {
						field = field char
						escaped = 0
					} else if (char == "\\") {
						escaped = 1
					} else if (char == ":") {
						output = output (count == 0 ? "" : "\t") field
						count++
						field = ""
					} else {
						field = field char
					}
				}
				print output (count == 0 ? "" : "\t") field
			}
		'
}

status() {
	need_nmcli

	nmcli_tab -f DEVICE,TYPE,STATE device status 2>/dev/null |
		awk -F '\t' '
			$1 != "lo" && $3 == "connected" {
				print "NET " $1
				found = 1
				exit
			}
			END {
				if (!found) {
					print "NET offline"
				}
			}
		'
}

devices() {
	need_nmcli
	nmcli_tab -f DEVICE,TYPE,STATE,CONNECTION device status
}

connections() {
	need_nmcli

	active=$(mktemp "${TMPDIR:-/tmp}/dwm-network-active.XXXXXX")
	trap 'rm -f "$active"' EXIT

	nmcli_tab -f NAME,UUID,TYPE,DEVICE connection show --active >"$active"
	nmcli_tab -f NAME,UUID,TYPE connection show |
		awk -F '\t' -v OFS='\t' '
			NR == FNR {
				active[$2] = 1
				device[$2] = $4
				next
			}
			{
				print $1, $2, $3, (active[$2] ? "yes" : "no"), device[$2]
			}
		' "$active" -
}

wifi_scan() {
	need_nmcli

	rescan=no
	ifname=

	while [ "$#" -gt 0 ]; do
		case "$1" in
		--rescan)
			[ "$#" -ge 2 ] || usage
			case "$2" in
			yes | no | auto)
				rescan=$2
				;;
			*)
				usage
				;;
			esac
			shift 2
			;;
		*)
			[ -z "$ifname" ] || usage
			ifname=$1
			shift
			;;
		esac
	done

	if [ -n "$ifname" ]; then
		nmcli_tab -f IN-USE,BSSID,SSID,SIGNAL,SECURITY,CHAN,DEVICE device wifi list ifname "$ifname" --rescan "$rescan"
	else
		nmcli_tab -f IN-USE,BSSID,SSID,SIGNAL,SECURITY,CHAN,DEVICE device wifi list --rescan "$rescan"
	fi
}

wifi_connect() {
	need_nmcli
	[ "$#" -ge 3 ] && [ "$#" -le 4 ] || usage

	ifname=$1
	bssid=$2
	ssid=$3
	password=${4:-}

	[ -n "$ifname" ] && [ -n "$bssid" ] && [ -n "$ssid" ] || usage

	if [ "$#" -eq 4 ]; then
		nmcli device wifi connect "$ssid" password "$password" ifname "$ifname" bssid "$bssid"
	else
		nmcli device wifi connect "$ssid" ifname "$ifname" bssid "$bssid"
	fi
}

connect_uuid() {
	need_nmcli
	[ "$#" -eq 1 ] || usage
	nmcli connection up uuid "$1"
}

disconnect_device() {
	need_nmcli
	[ "$#" -eq 1 ] || usage
	nmcli device disconnect "$1"
}

monitor() {
	need_nmcli

	nmcli monitor |
		while IFS= read -r _event; do
			printf '%s\n' changed
		done
}

editor() {
	if ! command -v nm-connection-editor >/dev/null 2>&1; then
		printf '%s\n' "nm-connection-editor not found" >&2
		exit 127
	fi

	exec nm-connection-editor
}

[ "$#" -ge 1 ] || usage

command=$1
shift

case "$command" in
status)
	[ "$#" -eq 0 ] || usage
	status
	;;
devices)
	[ "$#" -eq 0 ] || usage
	devices
	;;
connections)
	[ "$#" -eq 0 ] || usage
	connections
	;;
wifi-scan)
	wifi_scan "$@"
	;;
wifi-connect)
	wifi_connect "$@"
	;;
connect)
	connect_uuid "$@"
	;;
disconnect)
	disconnect_device "$@"
	;;
monitor)
	[ "$#" -eq 0 ] || usage
	monitor
	;;
editor)
	[ "$#" -eq 0 ] || usage
	editor
	;;
*)
	usage
	;;
esac
