#!/usr/bin/env bash
set -euo pipefail

browser_mimes=(
	x-scheme-handler/http
	x-scheme-handler/https
	text/html
	application/xhtml+xml
)

usage() {
	cat <<'EOF'
Usage:
  dwm-default-apps status
  dwm-default-apps browsers
  dwm-default-apps set-browser <desktop-id>
  dwm-default-apps set-mime <mime-type> <desktop-id>
  dwm-default-apps open [url]
EOF
}

need_cmd() {
	if ! command -v "$1" >/dev/null 2>&1; then
		printf 'dwm-default-apps: missing required command: %s\n' "$1" >&2
		return 1
	fi
}

data_dirs() {
	local dir

	printf '%s\n' "${XDG_DATA_HOME:-$HOME/.local/share}"

	IFS=':' read -r -a dirs <<<"${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
	for dir in "${dirs[@]}"; do
		[[ -n $dir ]] && printf '%s\n' "$dir"
	done
}

desktop_file_for_id() {
	local desktop_id=$1
	local dir

	while IFS= read -r dir; do
		if [[ -f $dir/applications/$desktop_id ]]; then
			printf '%s\n' "$dir/applications/$desktop_id"
			return 0
		fi
	done < <(data_dirs)

	return 1
}

desktop_value() {
	local key=$1
	local file=$2
	local line

	while IFS= read -r line; do
		case "$line" in
		"$key="*)
			printf '%s\n' "${line#*=}"
			return 0
			;;
		esac
	done <"$file"

	return 1
}

is_browser_desktop() {
	local file=$1
	local categories mime

	categories=$(desktop_value Categories "$file" 2>/dev/null || true)
	mime=$(desktop_value MimeType "$file" 2>/dev/null || true)

	[[ $categories == *WebBrowser* || $mime == *x-scheme-handler/http* ]]
}

list_browsers() {
	local dir file id name
	declare -A seen=()

	while IFS= read -r dir; do
		[[ -d $dir/applications ]] || continue
		for file in "$dir"/applications/*.desktop; do
			[[ -f $file ]] || continue
			id=${file##*/}
			[[ -z ${seen[$id]+x} ]] || continue
			seen[$id]=1

			if is_browser_desktop "$file"; then
				name=$(desktop_value Name "$file" 2>/dev/null || printf '%s' "$id")
				printf '%s\t%s\n' "$id" "$name"
			fi
		done
	done < <(data_dirs)
}

require_desktop_id() {
	local desktop_id=$1

	case "$desktop_id" in
	"" | */* | *..*)
		printf 'dwm-default-apps: invalid desktop id: %s\n' "$desktop_id" >&2
		return 1
		;;
	esac

	if ! desktop_file_for_id "$desktop_id" >/dev/null; then
		printf 'dwm-default-apps: desktop file not found: %s\n' "$desktop_id" >&2
		printf 'Run: dwm-default-apps browsers\n' >&2
		return 1
	fi
}

set_browser() {
	local desktop_id=$1
	local mime

	need_cmd xdg-settings
	need_cmd xdg-mime
	require_desktop_id "$desktop_id"

	xdg-settings set default-web-browser "$desktop_id"
	for mime in "${browser_mimes[@]}"; do
		xdg-mime default "$desktop_id" "$mime"
	done

	printf 'Default browser set to %s\n' "$desktop_id"
}

set_mime() {
	local mime=$1
	local desktop_id=$2

	need_cmd xdg-mime
	require_desktop_id "$desktop_id"

	xdg-mime default "$desktop_id" "$mime"
	printf 'Default for %s set to %s\n' "$mime" "$desktop_id"
}

status() {
	need_cmd xdg-settings
	need_cmd xdg-mime

	printf 'default-web-browser=%s\n' "$(xdg-settings get default-web-browser 2>/dev/null || true)"
	printf 'x-scheme-handler/http=%s\n' "$(xdg-mime query default x-scheme-handler/http 2>/dev/null || true)"
	printf 'x-scheme-handler/https=%s\n' "$(xdg-mime query default x-scheme-handler/https 2>/dev/null || true)"
	printf 'inode/directory=%s\n' "$(xdg-mime query default inode/directory 2>/dev/null || true)"
}

open_browser() {
	local url=${1:-https://}
	local current

	need_cmd xdg-settings
	need_cmd xdg-open

	current=$(xdg-settings get default-web-browser 2>/dev/null || true)
	if [[ -z $current ]]; then
		printf 'dwm-default-apps: no default browser configured.\n' >&2
		printf 'Run: dwm-default-apps browsers\n' >&2
		printf 'Then: dwm-default-apps set-browser <desktop-id>\n' >&2
		return 1
	fi

	exec xdg-open "$url"
}

main() {
	local cmd=${1:-}

	case "$cmd" in
	status)
		status
		;;
	browsers)
		list_browsers
		;;
	set-browser)
		[[ $# -eq 2 ]] || {
			usage >&2
			return 2
		}
		set_browser "$2"
		;;
	set-mime)
		[[ $# -eq 3 ]] || {
			usage >&2
			return 2
		}
		set_mime "$2" "$3"
		;;
	open)
		shift
		open_browser "${1:-https://}"
		;;
	-h | --help | help)
		usage
		;;
	*)
		usage >&2
		return 2
		;;
	esac
}

main "$@"
