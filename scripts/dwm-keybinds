#!/bin/bash

# Display DWM keybindings from docs/src/keybinds.md in a rofi menu.

SCRIPT_DIR="$(dirname "$(realpath "$0")")"
KEYBINDS_PATH="${HOME}/.local/share/dwm-dohc/docs/src/keybinds.md"
[ -f "$KEYBINDS_PATH" ] || KEYBINDS_PATH="${SCRIPT_DIR}/../docs/src/keybinds.md"

# Parse markdown: emit section headers and | `key` | description | rows
parse_bindings() {
    awk '
    /^## / {
        section = substr($0, 4)
        gsub(/^[ \t]+|[ \t]+$/, "", section)
        printf "  ── %s\n", section
        next
    }
    /^\| *`/ {
        line = $0
        gsub(/^\|[ \t]*/, "", line)
        gsub(/[ \t]*\|$/, "", line)
        n = split(line, cols, /[ \t]*\|[ \t]*/)
        if (n >= 2) {
            key = cols[1]
            desc = cols[2]
            # Strip backticks
            gsub(/`/, "", key)
            if (key ~ /^[-]+$/) next
            # Escape XML for rofi pango markup
            gsub(/&/, "\\&amp;", key);  gsub(/&/, "\\&amp;", desc)
            gsub(/</, "\\&lt;",  key);  gsub(/</, "\\&lt;",  desc)
            gsub(/>/, "\\&gt;",  key);  gsub(/>/, "\\&gt;",  desc)
            printf "<b>%s</b>  <i>%s</i>\n", key, desc
        }
    }
    ' "$KEYBINDS_PATH"
}

mapfile -t BINDINGS < <(parse_bindings)

printf '%s\n' "${BINDINGS[@]}" | rofi -dmenu -i -markup-rows -p "Keybinds:"

