#!/bin/bash

# Display DWM keybindings from KEYBINDS.md in a rofi menu.

KEYBINDS_PATH="${HOME}/.local/share/dwm-titus/KEYBINDS.md"
[ -f "$KEYBINDS_PATH" ] || KEYBINDS_PATH="$(dirname "$(realpath "$0")")/../KEYBINDS.md"

# Parse markdown tables: extract | `key` | description | rows
parse_bindings() {
    awk '
    /^\| *`/ {
        line = $0
        # Remove leading/trailing pipe and whitespace
        gsub(/^\|[ \t]*/, "", line)
        gsub(/[ \t]*\|$/, "", line)
        # Split on " | "
        n = split(line, cols, /[ \t]*\|[ \t]*/)
        if (n >= 2) {
            key = cols[1]
            desc = cols[2]
            # Strip backticks
            gsub(/`/, "", key)
            # Skip header separators
            if (key ~ /^[-]+$/) next
            # Escape XML for rofi markup
            gsub(/&/, "\\&amp;", key);  gsub(/&/, "\\&amp;", desc)
            gsub(/</, "\\&lt;",  key);  gsub(/</, "\\&lt;",  desc)
            gsub(/>/, "\\&gt;",  key);  gsub(/>/, "\\&gt;",  desc)
            printf "<b>%s</b>  <i>%s</i>\n", key, desc
        }
    }
    ' "$KEYBINDS_PATH"
}

mapfile -t BINDINGS < <(parse_bindings)

printf '%s\n' "${BINDINGS[@]}" | rofi -dmenu -i -markup-rows -p "DWM Keybindings:"

