#!/bin/sh
set -eu

usage() {
	printf '%s\n' "usage: dwm-quickshell-controls volume-status|volume-watch|volume-up [step]|volume-down [step]|volume-set <percent>|volume-toggle-mute|output-status|output-devices|output-set-default <sink>|mic-status|media-status|media-watch|media-play-pause|media-next|media-previous|bluetooth-status|bluetooth-devices|bluetooth-scan|bluetooth-power <on|off>|bluetooth-pair <address>|bluetooth-connect <address>|bluetooth-disconnect <address>" >&2
	exit 2
}

volume_step() {
	step=${1:-5%}

	case "$step" in
	[0-9]*%)
		printf '%s\n' "$step"
		;;
	*)
		usage
		;;
	esac
}

volume_percent() {
	percent=${1:-}
	percent=${percent%%%}

	case "$percent" in
	'' | *[!0-9]*)
		usage
		;;
	esac

	if [ "$percent" -gt 100 ]; then
		usage
	fi

	printf '%s%%\n' "$percent"
}

sink_mute_pactl() {
	pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null |
		awk '
			/Mute:/ {
				print $2
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

sink_volume_pactl() {
	pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null |
		awk '
			{
				for (i = 1; i <= NF; i++) {
					if ($i ~ /^[0-9]+%$/) {
						print $i
						found = 1
						exit
					}
				}
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

volume_status_pactl() {
	command -v pactl >/dev/null 2>&1 || return 1

	mute=$(sink_mute_pactl) || return 1
	volume=$(sink_volume_pactl) || return 1

	if [ "$mute" = yes ]; then
		printf 'VOL muted %s\n' "$volume"
	else
		printf 'VOL %s\n' "$volume"
	fi
}

volume_status_wpctl() {
	command -v wpctl >/dev/null 2>&1 || return 1

	wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null |
		awk '
			/Volume:/ {
				percent = int(($2 * 100) + 0.5)
				if ($0 ~ /\[MUTED\]/) {
					printf "VOL muted %d%%\n", percent
				} else {
					printf "VOL %d%%\n", percent
				}
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

volume_status() {
	if volume_status_pactl; then
		return 0
	fi

	if volume_status_wpctl; then
		return 0
	fi

	printf '%s\n' "VOL unavailable"
}

volume_watch() {
	# Compatibility snapshot for older deployed QML. Audio change notifications
	# are handled by Quickshell.Services.Pipewire; keeping a pactl subscription
	# here would orphan one client every time Quickshell reloads.
	volume_status
}

volume_up() {
	step=$(volume_step "${1:-}")

	if command -v pactl >/dev/null 2>&1; then
		pactl set-sink-volume @DEFAULT_SINK@ "+$step"
	elif command -v wpctl >/dev/null 2>&1; then
		wpctl set-volume @DEFAULT_AUDIO_SINK@ "$step+"
	else
		printf '%s\n' "pactl or wpctl not found" >&2
		exit 127
	fi
}

volume_down() {
	step=$(volume_step "${1:-}")

	if command -v pactl >/dev/null 2>&1; then
		pactl set-sink-volume @DEFAULT_SINK@ "-$step"
	elif command -v wpctl >/dev/null 2>&1; then
		wpctl set-volume @DEFAULT_AUDIO_SINK@ "$step-"
	else
		printf '%s\n' "pactl or wpctl not found" >&2
		exit 127
	fi
}

volume_set() {
	percent=$(volume_percent "${1:-}")

	if command -v pactl >/dev/null 2>&1; then
		pactl set-sink-volume @DEFAULT_SINK@ "$percent"
	elif command -v wpctl >/dev/null 2>&1; then
		wpctl set-volume @DEFAULT_AUDIO_SINK@ "$percent"
	else
		printf '%s\n' "pactl or wpctl not found" >&2
		exit 127
	fi
}

volume_toggle_mute() {
	if command -v pactl >/dev/null 2>&1; then
		pactl set-sink-mute @DEFAULT_SINK@ toggle
	elif command -v wpctl >/dev/null 2>&1; then
		wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
	else
		printf '%s\n' "pactl or wpctl not found" >&2
		exit 127
	fi
}

default_sink_pactl() {
	pactl info 2>/dev/null |
		awk -F': ' '
			$1 == "Default Sink" {
				print $2
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

output_devices_pactl() {
	command -v pactl >/dev/null 2>&1 || return 1

	default_sink=$(default_sink_pactl) || default_sink=

	pactl list sinks 2>/dev/null |
		awk -v default_sink="$default_sink" '
			function emit() {
				if (name == "") {
					return
				}
				if (description == "") {
					description = name
				}
				is_default = (name == default_sink) ? "1" : "0"
				printf "%s\t%s\t%s\n", name, description, is_default
			}
			/^Sink #[0-9]+/ {
				emit()
				name = ""
				description = ""
				next
			}
			/^[[:space:]]*Name:/ {
				sub(/^[[:space:]]*Name:[[:space:]]*/, "")
				name = $0
				next
			}
			/^[[:space:]]*Description:/ {
				sub(/^[[:space:]]*Description:[[:space:]]*/, "")
				description = $0
				next
			}
			END {
				emit()
				if (!seen) {
					exit 1
				}
			}
			name != "" {
				seen = 1
			}
		'
}

output_devices_wpctl() {
	command -v wpctl >/dev/null 2>&1 || return 1

	wpctl status 2>/dev/null |
		awk '
			function trim(value) {
				sub(/^[[:space:]]+/, "", value)
				sub(/[[:space:]]+$/, "", value)
				return value
			}
			$0 == "Audio" {
				audio = 1
				next
			}
			audio && /Sinks:/ {
				sinks = 1
				next
			}
			sinks && (/Sources:/ || /Filters:/ || /Streams:/ || $0 == "Video" || $0 == "Settings") {
				exit
			}
			sinks {
				line = $0
				if (line !~ /[0-9]+\./) {
					next
				}
				is_default = (line ~ /\*/) ? "1" : "0"
				sub(/^[^0-9]*/, "", line)
				id = line
				sub(/\..*/, "", id)
				description = line
				sub(/^[0-9]+\.[[:space:]]*/, "", description)
				sub(/[[:space:]]*\[vol:.*/, "", description)
				description = trim(description)
				if (id != "" && description != "") {
					printf "%s\t%s\t%s\n", id, description, is_default
					seen = 1
				}
			}
			END {
				if (!seen) {
					exit 1
				}
			}
		'
}

output_devices() {
	if output_devices_pactl; then
		return 0
	fi

	if output_devices_wpctl; then
		return 0
	fi

	printf '%s\n' "OUTPUT unavailable"
}

move_sink_inputs_pactl() {
	sink=$1

	pactl list short sink-inputs 2>/dev/null |
		awk 'NF > 0 { print $1 }' |
		while IFS= read -r input; do
			[ -n "$input" ] || continue
			pactl move-sink-input "$input" "$sink" >/dev/null 2>&1 || true
		done
}

output_set_default() {
	[ "$#" -eq 1 ] || usage

	if command -v pactl >/dev/null 2>&1; then
		if pactl set-default-sink "$1"; then
			move_sink_inputs_pactl "$1"
			return 0
		fi
	fi

	if command -v wpctl >/dev/null 2>&1; then
		wpctl set-default "$1"
	else
		printf '%s\n' "pactl or wpctl not found" >&2
		exit 127
	fi
}

mic_status_pactl() {
	command -v pactl >/dev/null 2>&1 || return 1

	pactl get-source-mute @DEFAULT_SOURCE@ 2>/dev/null |
		awk '
			/Mute:/ {
				if ($2 == "yes") {
					print "MIC muted"
				} else {
					print "MIC on"
				}
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

mic_status_wpctl() {
	command -v wpctl >/dev/null 2>&1 || return 1

	wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null |
		awk '
			/Volume:/ {
				if ($0 ~ /\[MUTED\]/) {
					print "MIC muted"
				} else {
					print "MIC on"
				}
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

mic_status() {
	if mic_status_pactl; then
		return 0
	fi

	if mic_status_wpctl; then
		return 0
	fi

	printf '%s\n' "MIC unavailable"
}

output_status() {
	if command -v pactl >/dev/null 2>&1; then
		pactl get-default-sink 2>/dev/null || printf '%s\n' "Output unavailable"
	elif command -v wpctl >/dev/null 2>&1; then
		wpctl status -n 2>/dev/null | awk '/\*/ { print; exit }' || printf '%s\n' "Output unavailable"
	else
		printf '%s\n' "Output unavailable"
	fi
}

media_status() {
	if ! command -v playerctl >/dev/null 2>&1; then
		printf '%s\n' "MEDIA unavailable"
		return 0
	fi

	format=$(printf '{{playerName}}\t{{status}}\t{{artist}}\t{{title}}')
	if ! playerctl metadata --format "$format" 2>/dev/null; then
		printf '%s\n' "MEDIA none"
	fi
}

media_watch() {
	if ! command -v playerctl >/dev/null 2>&1; then
		printf '%s\n' "MEDIA unavailable"
		return 0
	fi

	format=$(printf '{{playerName}}\t{{status}}\t{{artist}}\t{{title}}')
	if ! playerctl --follow metadata --format "$format" 2>/dev/null; then
		printf '%s\n' "MEDIA none"
	fi
}

playerctl_action() {
	[ "$#" -eq 1 ] || usage

	if ! command -v playerctl >/dev/null 2>&1; then
		printf '%s\n' "playerctl not found" >&2
		exit 127
	fi

	playerctl "$1"
}

bluetooth_status() {
	if ! command -v bluetoothctl >/dev/null 2>&1; then
		printf '%s\n' "BT unavailable"
		return 0
	fi

	powered=$(bluetoothctl show 2>/dev/null |
		awk '
			/^[[:space:]]*Powered:/ {
				print $2
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		') || {
		printf '%s\n' "BT unavailable"
		return 0
	}

	if [ "$powered" != yes ]; then
		printf '%s\n' "BT off"
		return 0
	fi

	count=$(bluetoothctl devices Connected 2>/dev/null | awk 'NF > 0 { count++ } END { print count + 0 }')
	printf 'BT %s\n' "$count"
}

bluetooth_devices() {
	command -v bluetoothctl >/dev/null 2>&1 || return 0
	bluetoothctl devices | while IFS=' ' read -r _ address name; do
		[ -n "$address" ] || continue
		info=$(bluetoothctl info "$address" 2>/dev/null || true)
		paired=$(printf '%s\n' "$info" | awk '/Paired:/ { print $2; exit }')
		connected=$(printf '%s\n' "$info" | awk '/Connected:/ { print $2; exit }')
		printf '%s\t%s\t%s\t%s\n' "$address" "$name" "${paired:-no}" "${connected:-no}"
	done
}

bluetooth_scan() {
	command -v bluetoothctl >/dev/null 2>&1 || return 1
	bluetoothctl --timeout 8 scan on >/dev/null 2>&1 || true
	bluetooth_devices
}

bluetooth_power() {
	[ "$#" -eq 1 ] || usage
	case $1 in on | off) bluetoothctl power "$1" ;; *) usage ;; esac
}

bluetooth_pair() {
	[ "$#" -eq 1 ] || usage
	bluetoothctl pair "$1" && bluetoothctl trust "$1" && bluetoothctl connect "$1"
}

bluetooth_connect() {
	[ "$#" -eq 1 ] || usage
	bluetoothctl connect "$1"
}

bluetooth_disconnect() {
	[ "$#" -eq 1 ] || usage
	bluetoothctl disconnect "$1"
}

[ "$#" -ge 1 ] || usage

command=$1
shift

case "$command" in
volume-status)
	[ "$#" -eq 0 ] || usage
	volume_status
	;;
volume-watch)
	[ "$#" -eq 0 ] || usage
	volume_watch
	;;
volume-up)
	[ "$#" -le 1 ] || usage
	volume_up "${1:-}"
	;;
volume-down)
	[ "$#" -le 1 ] || usage
	volume_down "${1:-}"
	;;
volume-set)
	[ "$#" -eq 1 ] || usage
	volume_set "$1"
	;;
volume-toggle-mute)
	[ "$#" -eq 0 ] || usage
	volume_toggle_mute
	;;
output-devices)
	[ "$#" -eq 0 ] || usage
	output_devices
	;;
output-set-default)
	[ "$#" -eq 1 ] || usage
	output_set_default "$1"
	;;
mic-status)
	[ "$#" -eq 0 ] || usage
	mic_status
	;;
output-status)
	[ "$#" -eq 0 ] || usage
	output_status
	;;
media-status)
	[ "$#" -eq 0 ] || usage
	media_status
	;;
media-watch)
	[ "$#" -eq 0 ] || usage
	media_watch
	;;
media-play-pause)
	[ "$#" -eq 0 ] || usage
	playerctl_action play-pause
	;;
media-next)
	[ "$#" -eq 0 ] || usage
	playerctl_action next
	;;
media-previous)
	[ "$#" -eq 0 ] || usage
	playerctl_action previous
	;;
bluetooth-status)
	[ "$#" -eq 0 ] || usage
	bluetooth_status
	;;
bluetooth-devices)
	[ "$#" -eq 0 ] || usage
	bluetooth_devices
	;;
bluetooth-scan)
	[ "$#" -eq 0 ] || usage
	bluetooth_scan
	;;
bluetooth-power)
	bluetooth_power "$@"
	;;
bluetooth-pair)
	bluetooth_pair "$@"
	;;
bluetooth-connect)
	bluetooth_connect "$@"
	;;
bluetooth-disconnect)
	bluetooth_disconnect "$@"
	;;
*)
	usage
	;;
esac
