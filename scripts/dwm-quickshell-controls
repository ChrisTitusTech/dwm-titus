#!/bin/sh
set -eu

usage() {
	printf '%s\n' "usage: dwm-quickshell-controls volume-status|volume-up [step]|volume-down [step]|volume-toggle-mute|mic-status" >&2
	exit 2
}

volume_step() {
	step=${1:-5%}

	case "$step" in
	[0-9]*%)
		printf '%s\n' "$step"
		;;
	*)
		usage
		;;
	esac
}

sink_mute_pactl() {
	pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null |
		awk '
			/Mute:/ {
				print $2
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

sink_volume_pactl() {
	pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null |
		awk '
			{
				for (i = 1; i <= NF; i++) {
					if ($i ~ /^[0-9]+%$/) {
						print $i
						found = 1
						exit
					}
				}
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

volume_status_pactl() {
	command -v pactl >/dev/null 2>&1 || return 1

	mute=$(sink_mute_pactl) || return 1
	volume=$(sink_volume_pactl) || return 1

	if [ "$mute" = yes ]; then
		printf 'VOL muted %s\n' "$volume"
	else
		printf 'VOL %s\n' "$volume"
	fi
}

volume_status_wpctl() {
	command -v wpctl >/dev/null 2>&1 || return 1

	wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null |
		awk '
			/Volume:/ {
				percent = int(($2 * 100) + 0.5)
				if ($0 ~ /\[MUTED\]/) {
					printf "VOL muted %d%%\n", percent
				} else {
					printf "VOL %d%%\n", percent
				}
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

volume_status() {
	if volume_status_pactl; then
		return 0
	fi

	if volume_status_wpctl; then
		return 0
	fi

	printf '%s\n' "VOL unavailable"
}

volume_up() {
	step=$(volume_step "${1:-}")

	if command -v pactl >/dev/null 2>&1; then
		pactl set-sink-volume @DEFAULT_SINK@ "+$step"
	elif command -v wpctl >/dev/null 2>&1; then
		wpctl set-volume @DEFAULT_AUDIO_SINK@ "$step+"
	else
		printf '%s\n' "pactl or wpctl not found" >&2
		exit 127
	fi
}

volume_down() {
	step=$(volume_step "${1:-}")

	if command -v pactl >/dev/null 2>&1; then
		pactl set-sink-volume @DEFAULT_SINK@ "-$step"
	elif command -v wpctl >/dev/null 2>&1; then
		wpctl set-volume @DEFAULT_AUDIO_SINK@ "$step-"
	else
		printf '%s\n' "pactl or wpctl not found" >&2
		exit 127
	fi
}

volume_toggle_mute() {
	if command -v pactl >/dev/null 2>&1; then
		pactl set-sink-mute @DEFAULT_SINK@ toggle
	elif command -v wpctl >/dev/null 2>&1; then
		wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
	else
		printf '%s\n' "pactl or wpctl not found" >&2
		exit 127
	fi
}

mic_status_pactl() {
	command -v pactl >/dev/null 2>&1 || return 1

	pactl get-source-mute @DEFAULT_SOURCE@ 2>/dev/null |
		awk '
			/Mute:/ {
				if ($2 == "yes") {
					print "MIC muted"
				} else {
					print "MIC on"
				}
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

mic_status_wpctl() {
	command -v wpctl >/dev/null 2>&1 || return 1

	wpctl get-volume @DEFAULT_AUDIO_SOURCE@ 2>/dev/null |
		awk '
			/Volume:/ {
				if ($0 ~ /\[MUTED\]/) {
					print "MIC muted"
				} else {
					print "MIC on"
				}
				found = 1
				exit
			}
			END {
				if (!found) {
					exit 1
				}
			}
		'
}

mic_status() {
	if mic_status_pactl; then
		return 0
	fi

	if mic_status_wpctl; then
		return 0
	fi

	printf '%s\n' "MIC unavailable"
}

[ "$#" -ge 1 ] || usage

command=$1
shift

case "$command" in
volume-status)
	[ "$#" -eq 0 ] || usage
	volume_status
	;;
volume-up)
	[ "$#" -le 1 ] || usage
	volume_up "${1:-}"
	;;
volume-down)
	[ "$#" -le 1 ] || usage
	volume_down "${1:-}"
	;;
volume-toggle-mute)
	[ "$#" -eq 0 ] || usage
	volume_toggle_mute
	;;
mic-status)
	[ "$#" -eq 0 ] || usage
	mic_status
	;;
*)
	usage
	;;
esac
