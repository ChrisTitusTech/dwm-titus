#!/bin/sh
set -eu

repo_dir=$(
	unset CDPATH
	cd -- "$(dirname -- "$0")/.." && pwd
)

config_home=${XDG_CONFIG_HOME:-${HOME:-}/.config}
dwm_config_dir=$config_home/dwm-titus

config_file() {
	name=$1
	if [ -f "$dwm_config_dir/$name" ]; then
		printf '%s\n' "$dwm_config_dir/$name"
	else
		printf '%s\n' "$repo_dir/config/$name"
	fi
}

power_config_file=$dwm_config_dir/power.conf

is_uint() {
	case ${1:-} in
	"" | *[!0123456789]*) return 1 ;;
	*) return 0 ;;
	esac
}

strip_space() {
	printf '%s' "$1" | tr -d '[:space:]'
}

normalize_seconds() {
	power_value=${1:-}
	power_fallback=${2:-600}

	if ! is_uint "$power_value"; then
		power_value=$power_fallback
	fi
	if [ "$power_value" -lt 60 ]; then
		power_value=60
	fi
	if [ "$power_value" -gt 86400 ]; then
		power_value=86400
	fi

	printf '%s\n' "$power_value"
}

power_bool() {
	case $(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]') in
	1 | true | yes | on | enabled) printf '1\n' ;;
	*) printf '0\n' ;;
	esac
}

read_power_config() {
	power_dpms_enabled=0
	power_dpms_timeout=600
	power_lock_enabled=0
	power_lock_managed=0
	power_lock_timeout=600
	power_lock_after=5
	power_config_managed=0

	[ -r "$power_config_file" ] || return 0
	power_config_managed=1

	while IFS='=' read -r power_key power_value || [ -n "$power_key" ]; do
		power_key=$(strip_space "$power_key")
		case $power_key in
		"" | \#*) continue ;;
		esac

		power_value=${power_value%%#*}
		power_value=$(strip_space "$power_value")

		case $power_key in
		dpms_enabled) power_dpms_enabled=$(power_bool "$power_value") ;;
		dpms_timeout) power_dpms_timeout=$(normalize_seconds "$power_value" "$power_dpms_timeout") ;;
		lock_enabled) power_lock_enabled=$(power_bool "$power_value") ;;
		lock_managed) power_lock_managed=$(power_bool "$power_value") ;;
		lock_timeout) power_lock_timeout=$(normalize_seconds "$power_value" "$power_lock_timeout") ;;
		lock_after)
			if is_uint "$power_value" && [ "$power_value" -le 3600 ]; then
				power_lock_after=$power_value
			fi
			;;
		esac
	done <"$power_config_file"
}

write_power_config() {
	mkdir -p "$dwm_config_dir"
	power_tmp=$(mktemp "${TMPDIR:-/tmp}/dwm-power.XXXXXX")
	{
		printf '%s\n' '# dwm-titus power settings'
		printf 'dpms_enabled=%s\n' "$power_dpms_enabled"
		printf 'dpms_timeout=%s\n' "$power_dpms_timeout"
		printf 'lock_enabled=%s\n' "$power_lock_enabled"
		printf 'lock_managed=%s\n' "$power_lock_managed"
		printf 'lock_timeout=%s\n' "$power_lock_timeout"
		printf 'lock_after=%s\n' "$power_lock_after"
	} >"$power_tmp"
	mv "$power_tmp" "$power_config_file"
	power_config_managed=1
}

start_configured_light_locker() {
	command -v light-locker >/dev/null 2>&1 || return 0

	if command -v pgrep >/dev/null 2>&1 &&
		pgrep -u "$(id -u)" -x light-locker >/dev/null 2>&1; then
		return 0
	fi

	light-locker >/dev/null 2>&1 &
}

stop_configured_light_locker() {
	command -v pgrep >/dev/null 2>&1 || return 0
	command -v pkill >/dev/null 2>&1 || return 0

	if pgrep -u "$(id -u)" -x light-locker >/dev/null 2>&1; then
		pkill -u "$(id -u)" -x light-locker
	fi
}

power_apply_dpms_settings() {
	command -v xset >/dev/null 2>&1 || return 1

	if [ "$power_dpms_enabled" = 1 ]; then
		xset +dpms
		xset dpms "$power_dpms_timeout" "$power_dpms_timeout" "$power_dpms_timeout"
	else
		xset -dpms
	fi
}

power_apply_lock_settings() {
	power_status=0

	if command -v xset >/dev/null 2>&1; then
		if [ "$power_lock_enabled" = 1 ]; then
			xset s "$power_lock_timeout"
		else
			xset s off
			xset s noblank
		fi
	else
		power_status=1
	fi

	if [ "$power_lock_enabled" = 1 ]; then
		if command -v light-locker >/dev/null 2>&1 &&
			command -v gsettings >/dev/null 2>&1 &&
			gsettings set apps.light-locker lock-after-screensaver "$power_lock_after" &&
			gsettings set apps.light-locker lock-on-suspend true; then
			start_configured_light_locker
		else
			power_status=1
		fi
	elif { [ "${power_config_managed:-0}" = 1 ] || [ "${power_lock_managed:-0}" = 1 ]; } &&
		command -v gsettings >/dev/null 2>&1; then
		if ! gsettings set apps.light-locker lock-after-screensaver 0 ||
			! gsettings set apps.light-locker lock-on-suspend false; then
			power_status=1
		fi
	fi

	if [ "$power_lock_enabled" = 0 ] &&
		{ [ "${power_config_managed:-0}" = 1 ] || [ "${power_lock_managed:-0}" = 1 ]; }; then
		stop_configured_light_locker || power_status=1
	fi

	return "$power_status"
}

power_apply() {
	read_power_config
	power_status=0
	power_apply_dpms_settings || power_status=1
	power_apply_lock_settings || power_status=1
	return "$power_status"
}

power_status() {
	read_power_config

	power_xset_available=0
	power_live_dpms_enabled=$power_dpms_enabled
	power_live_dpms_timeout=$power_dpms_timeout
	power_live_lock_timeout=$power_lock_timeout

	if command -v xset >/dev/null 2>&1 && power_xset_out=$(xset q 2>/dev/null); then
		power_xset_available=1

		power_value=$(printf '%s\n' "$power_xset_out" |
			awk '/DPMS is/ { print $3; exit }')
		case $power_value in
		Enabled | enabled) power_live_dpms_enabled=1 ;;
		Disabled | disabled) power_live_dpms_enabled=0 ;;
		esac

		power_value=$(printf '%s\n' "$power_xset_out" |
			awk '/Standby:/ { for (i = 1; i <= NF; i++) if ($i == "Off:") { print $(i + 1); exit } }')
		if is_uint "$power_value"; then
			power_live_dpms_timeout=$power_value
		fi

		power_value=$(printf '%s\n' "$power_xset_out" |
			awk '/timeout:/ { for (i = 1; i <= NF; i++) if ($i == "timeout:") { print $(i + 1); exit } }')
		if is_uint "$power_value" && [ "$power_value" -gt 0 ]; then
			power_live_lock_timeout=$power_value
		fi
	fi

	power_lock_available=0
	power_live_lock_after=$power_lock_after
	if command -v light-locker >/dev/null 2>&1 &&
		command -v gsettings >/dev/null 2>&1 &&
		power_gsettings_value=$(gsettings get apps.light-locker lock-after-screensaver 2>/dev/null); then
		power_lock_available=1
		power_value=$(printf '%s\n' "$power_gsettings_value" | awk '{ print $NF }')
		if is_uint "$power_value"; then
			power_live_lock_after=$power_value
		fi
	fi

	power_live_lock_enabled=$power_lock_enabled
	if [ "$power_xset_available" = 1 ] && [ "$power_lock_available" = 1 ]; then
		if [ "$power_live_lock_after" -gt 0 ] && [ "$power_live_lock_timeout" -gt 0 ]; then
			power_live_lock_enabled=1
		else
			power_live_lock_enabled=0
		fi
	fi

	power_lock_running=0
	if command -v pgrep >/dev/null 2>&1 &&
		pgrep -u "$(id -u)" -x light-locker >/dev/null 2>&1; then
		power_lock_running=1
	fi

	printf 'dpms_available\t%s\n' "$power_xset_available"
	printf 'dpms_enabled\t%s\n' "$power_live_dpms_enabled"
	printf 'dpms_timeout\t%s\n' "$power_live_dpms_timeout"
	printf 'lock_available\t%s\n' "$power_lock_available"
	printf 'lock_enabled\t%s\n' "$power_live_lock_enabled"
	printf 'lock_timeout\t%s\n' "$power_live_lock_timeout"
	printf 'lock_after\t%s\n' "$power_live_lock_after"
	printf 'lock_running\t%s\n' "$power_lock_running"
	printf 'config_file\t%s\n' "$power_config_file"
}

power_set_dpms() {
	case ${1:-} in
	on | enable | enabled | 1) power_new_enabled=1 ;;
	off | disable | disabled | 0) power_new_enabled=0 ;;
	*)
		printf 'usage: %s power-dpms on|off\n' "$0" >&2
		return 2
		;;
	esac

	read_power_config
	power_dpms_enabled=$power_new_enabled
	write_power_config
	power_apply_dpms_settings
	notify "Display power updated" "DPMS $([ "$power_dpms_enabled" = 1 ] && printf enabled || printf disabled)"
	printf 'power-dpms\t%s\n' "$power_dpms_enabled"
}

power_set_dpms_timeout() {
	read_power_config
	power_new_timeout=$(normalize_seconds "${1:-}" "$power_dpms_timeout")
	power_dpms_enabled=1
	power_dpms_timeout=$power_new_timeout
	write_power_config
	power_apply_dpms_settings
	notify "Display power updated" "DPMS timeout ${power_dpms_timeout}s"
	printf 'power-dpms-timeout\t%s\n' "$power_dpms_timeout"
}

power_set_lock() {
	case ${1:-} in
	on | enable | enabled | 1) power_new_enabled=1 ;;
	off | disable | disabled | 0) power_new_enabled=0 ;;
	*)
		printf 'usage: %s power-lock on|off\n' "$0" >&2
		return 2
		;;
	esac

	read_power_config
	power_lock_enabled=$power_new_enabled
	power_lock_managed=1
	write_power_config
	power_apply_lock_settings
	notify "Locking updated" "Auto lock $([ "$power_lock_enabled" = 1 ] && printf enabled || printf disabled)"
	printf 'power-lock\t%s\n' "$power_lock_enabled"
}

power_set_lock_timeout() {
	read_power_config
	power_new_timeout=$(normalize_seconds "${1:-}" "$power_lock_timeout")
	power_lock_enabled=1
	power_lock_managed=1
	power_lock_timeout=$power_new_timeout
	write_power_config
	power_apply_lock_settings
	notify "Locking updated" "Auto lock timeout ${power_lock_timeout}s"
	printf 'power-lock-timeout\t%s\n' "$power_lock_timeout"
}

notify() {
	if command -v notify-send >/dev/null 2>&1; then
		notify-send -a "DWM Control Center" "$@" 2>/dev/null || true
	fi
}

launch_background() {
	if [ "${DWM_TEST_SYNC:-0}" = 1 ]; then
		"$@"
		return
	fi

	if command -v setsid >/dev/null 2>&1; then
		setsid "$@" >/dev/null 2>&1 &
	else
		"$@" >/dev/null 2>&1 &
	fi
}

terminal_run() {
	if command -v dwm-terminal >/dev/null 2>&1; then
		launch_background dwm-terminal -e sh -c "$1"
	else
		sh -c "$1"
	fi
}

health() {
	health_helper=$repo_dir/scripts/dwm-system-health
	if [ ! -x "$health_helper" ]; then
		health_helper=$(command -v dwm-system-health 2>/dev/null || true)
	fi
	if [ -z "$health_helper" ]; then
		printf 'error\tSystem health helper\tdwm-system-health missing\n'
		return 1
	fi

	"$health_helper" scan-user | awk -F '\t' '
		$1 == "check" {
			status = $3
			if (status == "info") status = "ok"
			printf "%s\t%s\t%s\n", status, $5, $6
		}
	'
}

info() {
	os_name=unknown
	if [ -r /etc/os-release ]; then
		os_name=$(awk -F= '$1 == "PRETTY_NAME" { gsub(/^"|"$/, "", $2); print $2; exit }' /etc/os-release)
	fi

	compositor=stopped
	if pgrep -x picom >/dev/null 2>&1; then
		compositor=running
	fi

	audio=unavailable
	if command -v pactl >/dev/null 2>&1; then
		audio=$(pactl info 2>/dev/null | awk -F': ' '$1 == "Server Name" { print $2; exit }')
		audio=${audio:-available}
	elif command -v wpctl >/dev/null 2>&1; then
		audio=wireplumber
	fi

	printf 'OS\t%s\n' "$os_name"
	printf 'Kernel\t%s\n' "$(uname -sr)"
	printf 'Host\t%s\n' "$(hostname 2>/dev/null || printf unknown)"
	printf 'Uptime\t%s\n' "$(uptime -p 2>/dev/null || uptime 2>/dev/null || printf unknown)"
	printf 'Terminal\t%s\n' "${TERMINAL:-dwm-terminal}"
	printf 'Compositor\t%s\n' "$compositor"
	printf 'Audio\t%s\n' "$audio"
	printf 'Theme\t%s\n' "$(active_theme)"
}

active_theme() {
	awk '
		$0 ~ /^\[active\]/ { active = 1; next }
		$0 ~ /^\[/ { active = 0 }
		active && $1 == "theme" {
			value = $0
			sub(/^[^=]*=[[:space:]]*/, "", value)
			sub(/[[:space:]]*#.*/, "", value)
			gsub(/"/, "", value)
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
			print value
			exit
		}
	' "$(config_file themes.toml)"
}

theme_exists() {
	name=$1
	awk -v section="[theme.$name]" '$0 == section { found = 1 } END { exit found ? 0 : 1 }' "$(config_file themes.toml)"
}

themes() {
	active=$(active_theme)
	awk -v active="$active" '
		/^\[theme\.[^]]+\]/ {
			name = $0
			sub(/^\[theme\./, "", name)
			sub(/\]$/, "", name)
			status = name == active ? "active" : "available"
			printf "%s\t%s\n", status, name
		}
	' "$(config_file themes.toml)"
}

ensure_user_themes_file() {
	file=$dwm_config_dir/themes.toml
	if [ ! -f "$file" ]; then
		mkdir -p "$dwm_config_dir"
		cp "$repo_dir/config/themes.toml" "$file"
	fi
	printf '%s\n' "$file"
}

theme_set() {
	name=$1
	if ! theme_exists "$name"; then
		printf 'unknown theme: %s\n' "$name" >&2
		return 1
	fi

	file=$(ensure_user_themes_file)
	tmp=$(mktemp "${TMPDIR:-/tmp}/dwm-theme.XXXXXX")
	trap 'rm -f "$tmp"' EXIT INT HUP TERM
	awk -v name="$name" '
		$0 ~ /^\[active\]/ {
			active = 1
			print
			next
		}
		$0 ~ /^\[/ {
			active = 0
		}
		active && $1 == "theme" {
			sub(/theme[[:space:]]*=.*/, "theme = \"" name "\"")
			print
			done = 1
			next
		}
		{ print }
		END {
			if (!done) {
				print ""
				print "[active]"
				print "theme = \"" name "\""
			}
		}
	' "$file" >"$tmp"
	mv "$tmp" "$file"
	trap - EXIT INT HUP TERM

	notify "Theme changed" "$name"
	printf 'theme\t%s\n' "$name"
}

keybinds() {
	awk '
		function value(line, key, pattern, result) {
			pattern = key "=\"[^\"]*\""
			if (match(line, pattern)) {
				result = substr(line, RSTART + length(key) + 2, RLENGTH - length(key) - 3)
				return result
			}
			return ""
		}

		/^[[:space:]]*\{/ && /desc=/ {
			mod = value($0, "mod")
			key = value($0, "key")
			desc = value($0, "desc")
			if (key == "") {
				next
			}
			label = mod == "" ? key : mod "+" key
			gsub(/SUPER/, "Super", label)
			gsub(/SHIFT/, "Shift", label)
			gsub(/CTRL/, "Ctrl", label)
			gsub(/ALT/, "Alt", label)
			gsub(/\+/, " + ", label)
			printf "%s\t%s\n", label, desc
		}
	' "$(config_file hotkeys.toml)"
}

restart_picom() {
	pkill -x picom 2>/dev/null || true
	if command -v picom >/dev/null 2>&1; then
		launch_background picom
		notify "Picom restarted"
	else
		printf 'picom is not installed\n' >&2
		return 1
	fi
}

restart_quickshell() {
	config=$config_home/quickshell/shell.qml
	if [ ! -f "$config" ]; then
		printf 'quickshell config is unavailable: %s\n' "$config" >&2
		return 1
	fi

	pkill -x quickshell 2>/dev/null || true
	if command -v quickshell >/dev/null 2>&1; then
		launch_background quickshell --no-duplicate
		notify "Quickshell restarted"
	else
		printf 'quickshell is not installed\n' >&2
		return 1
	fi
}

reload_wallpaper() {
	wallpaper_dir=${HOME:-}/Pictures/backgrounds

	if ! command -v feh >/dev/null 2>&1; then
		printf 'feh is unavailable\n' >&2
		return 1
	fi
	if [ ! -d "$wallpaper_dir" ]; then
		printf 'wallpaper folder is unavailable: %s\n' "$wallpaper_dir" >&2
		notify "Wallpaper folder missing" "$wallpaper_dir"
		return 1
	fi
	if ! find "$wallpaper_dir" -type f \
		\( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' -o -iname '*.bmp' -o -iname '*.gif' \) \
		-print -quit | grep -q .; then
		printf 'no loadable wallpaper images found in %s\n' "$wallpaper_dir" >&2
		notify "No wallpapers found" "$wallpaper_dir"
		return 1
	fi
	if find "$wallpaper_dir" -type f \
		\( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' -o -iname '*.bmp' -o -iname '*.gif' \) \
		-exec feh --randomize --bg-fill {} + >/dev/null 2>&1; then
		notify "Wallpaper reloaded"
	else
		printf 'failed to reload wallpaper from %s\n' "$wallpaper_dir" >&2
		return 1
	fi
}

toggle_compositor() {
	if pgrep -x picom >/dev/null 2>&1; then
		pkill -x picom
		notify "Compositor stopped"
	else
		restart_picom
	fi
}

restart_networkmanager() {
	if command -v systemctl >/dev/null 2>&1; then
		terminal_run "sudo systemctl restart NetworkManager"
	else
		printf 'systemctl is unavailable\n' >&2
		return 1
	fi
}

dependency_check() {
	terminal_run "$repo_dir/scripts/check-deps.sh; printf '\\nPress enter to close...'; read -r _"
}

install_missing_deps() {
	terminal_run "cd '$repo_dir' && ./install.sh; printf '\\nPress enter to close...'; read -r _"
}

open_wallpapers() {
	if command -v xdg-open >/dev/null 2>&1; then
		launch_background xdg-open "${HOME:-}/Pictures/backgrounds"
	else
		printf 'xdg-open is unavailable\n' >&2
		return 1
	fi
}

gtk_settings() {
	if command -v nwg-look >/dev/null 2>&1; then
		launch_background nwg-look
	else
		printf 'nwg-look is unavailable\n' >&2
		return 1
	fi
}

action() {
	case ${1:-} in
	restart-picom) restart_picom ;;
	restart-quickshell) restart_quickshell ;;
	reload-wallpaper) reload_wallpaper ;;
	toggle-compositor) toggle_compositor ;;
	restart-networkmanager) restart_networkmanager ;;
	dependency-check) dependency_check ;;
	install-missing-deps) install_missing_deps ;;
	open-wallpapers) open_wallpapers ;;
	gtk-settings) gtk_settings ;;
	terminal) launch_background dwm-terminal ;;
	browser) launch_background dwm-default-apps open https:// ;;
	*)
		printf 'unknown action: %s\n' "${1:-}" >&2
		return 2
		;;
	esac
	printf 'action\t%s\n' "$1"
}

usage() {
	printf 'usage: %s health|info|themes|theme-set <name>|keybinds|power-status|power-apply|power-dpms on|off|power-dpms-timeout <seconds>|power-lock on|off|power-lock-timeout <seconds>|action <name>\n' "$0" >&2
}

case ${1:-} in
health) health ;;
info) info ;;
themes) themes ;;
theme-set)
	if [ $# -ne 2 ]; then
		usage
		exit 2
	fi
	theme_set "$2"
	;;
keybinds) keybinds ;;
power-status) power_status ;;
power-apply) power_apply ;;
power-dpms)
	if [ $# -ne 2 ]; then
		usage
		exit 2
	fi
	power_set_dpms "$2"
	;;
power-dpms-timeout)
	if [ $# -ne 2 ]; then
		usage
		exit 2
	fi
	power_set_dpms_timeout "$2"
	;;
power-lock)
	if [ $# -ne 2 ]; then
		usage
		exit 2
	fi
	power_set_lock "$2"
	;;
power-lock-timeout)
	if [ $# -ne 2 ]; then
		usage
		exit 2
	fi
	power_set_lock_timeout "$2"
	;;
action)
	if [ $# -ne 2 ]; then
		usage
		exit 2
	fi
	action "$2"
	;;
*)
	usage
	exit 2
	;;
esac
