# Active theme — managed by theme-apply.sh, do not edit manually.
# Change the theme in ~/.config/dwm-titus/themes.toml instead.
theme = Nord
window-theme = ghostty
window-height = 35
window-width = 100
background-opacity = 0.95
font-family = MesloLGS NF
font-family-bold = MesloLGS NF
font-family-italic = MesloLGS NF
font-family-bold-italic = MesloLGS NF
font-size = 14
gtk-titlebar = false
confirm-close-surface = false


#keybind = ctrl+up=scroll_page_lines:5
#keybind = ctrl+down=scroll_page_lines:-5 

keybind = ctrl+up=scroll_page_up
keybind = ctrl+down=scroll_page_down
